# Felogix — variáveis de ambiente
# Copie este arquivo para .env e preencha com os valores reais.
# O .env NUNCA deve ser versionado (está no .gitignore).

# Segredo usado para assinar os tokens JWT.
# DEVE ser fixo e secreto. Se mudar, todos os usuários são deslogados.
# Gere um novo com: node -e "console.log('flx_'+require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Banco de dados PostgreSQL
DB_PASS=

# Notificações push (Web Push / VAPID)
# Se não definidas, são geradas automaticamente a cada restart (inscrições existentes são invalidadas).
# Gere um par fixo com: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Senha do admin (felipe.sousa@felogix.com.br)
ADMIN_PASS=

# Conta de envio de email (Gmail — senha de app)
MAIL_USER=
MAIL_PASS=

# Porta da aplicação (opcional, padrão 3000)
PORT=3000

# Integração com Traccar (GPS Tracking)
# Host e porta do servidor Traccar
TRACCAR_HOST=localhost
TRACCAR_PORT=8082

# Credenciais do Traccar (usuário e senha do servidor)
TRACCAR_USER=admin
TRACCAR_PASS=admin

# Email de destino para lembrete mensal de faturas
LEMBRETE_EMAIL=felogix.br@gmail.com
